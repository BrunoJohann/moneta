# Backend API URL
NEXT_PUBLIC_API_URL="http://localhost:3001/api"

# App URL (for absolute links)
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Google OAuth — set to "true" to show the "Login com Google" button
# Requires GOOGLE_CLIENT_ID and GOOGLE_CLIENT_SECRET configured in the backend
# NEXT_PUBLIC_GOOGLE_AUTH_ENABLED=true
